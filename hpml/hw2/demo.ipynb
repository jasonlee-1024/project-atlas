   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# p 的取值范围（不能包含0，因为 log(0) 不存在）\n",
    "p = np.linspace(0.001, 1, 500)\n",
    "\n",
    "# 计算 log(p)\n",
    "y = np.log(p)\n",
    "\n",
    "# 画图\n",
    "plt.figure()\n",
    "plt.plot(p, y)\n",
    "\n",
    "plt.xlabel(\"p\")\n",
    "plt.ylabel(\"log(p)\")\n",
    "plt.title(\"log(p) Function\")\n",
    "\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  }
 ],
